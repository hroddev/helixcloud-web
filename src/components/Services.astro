---
import { siteData } from "../siteData";
---

<section id="services" class="py-24 bg-[#050505]">
    <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
                Nuestros <span class="text-gradient">Servicios</span>
            </h2>
            <p class="text-gray-400 max-w-2xl mx-auto">
                Soluciones integrales de infraestructura cloud, Microsoft 365 y DevOps diseñadas para empresas en Panamá.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                siteData.services.map((service) => (
                    <div class="p-8 rounded-2xl bg-black border border-white/10 hover:border-blue-500/30 transition-all duration-300 group">
                        <h3 class="text-xl font-bold mb-3 text-white group-hover:text-blue-400 transition-colors">
                            {service.title}
                        </h3>
                        <p class="text-gray-400 leading-relaxed text-sm mb-6">
                            {service.description}
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {service.tags.map((tag) => (
                                <span class="text-xs px-3 py-1 bg-blue-500/10 text-blue-400 rounded-full border border-blue-500/20">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
