---
import { siteData } from "../siteData";
---

<section id="success-cases" class="py-24 bg-[#050505]">
    <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
                Resultados <span class="text-gradient">Reales</span>
            </h2>
            <p class="text-gray-400 max-w-2xl mx-auto">
                Empresas que crecieron con infraestructura confiable y costos controlados.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {siteData.successCases.map((caseItem) => (
                <div class="p-8 rounded-2xl bg-black border border-white/10 hover:border-blue-500/30 transition-all group">
                    <!-- Industry Badge -->
                    <div class="inline-block px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 mb-4">
                        <span class="text-sm text-blue-400 font-semibold">
                            {caseItem.industry}
                        </span>
                    </div>
                    <p class="text-gray-400 text-xs mb-6">
                        {caseItem.size}
                    </p>

                    <!-- Challenge -->
                    <div class="mb-6">
                        <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wide mb-2">
                            Desafío
                        </h3>
                        <p class="text-gray-300 text-sm leading-relaxed">
                            {caseItem.challenge}
                        </p>
                    </div>

                    <!-- Solution -->
                    <div class="mb-6">
                        <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wide mb-2">
                            Solución
                        </h3>
                        <p class="text-gray-300 text-sm leading-relaxed">
                            {caseItem.solution}
                        </p>
                    </div>

                    <!-- Result -->
                    <div class="pt-6 border-t border-white/10">
                        <h3 class="text-sm font-bold text-gray-300 uppercase tracking-wide mb-2">
                            Resultado
                        </h3>
                        <p class="text-blue-400 font-semibold text-sm leading-relaxed">
                            {caseItem.result}
                        </p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
