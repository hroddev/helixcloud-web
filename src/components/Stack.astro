---
import { siteData } from "../siteData";
---

<section id="stack" class="py-24 bg-black relative">
    <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
                {siteData.stackTitle.split(" ")[0]}
                <span class="text-blue-500"
                    >{siteData.stackTitle.split(" ").slice(1).join(" ")}</span
                >
            </h2>
            <p class="text-gray-400 max-w-2xl mx-auto">
                {siteData.stackDescription}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            {
                siteData.stackBenefits.map((benefit) => (
                    <div class="p-8 rounded-2xl bg-[#050505] border border-white/5 hover:border-blue-500/20 transition-all group">
                        <h3 class="text-lg font-bold mb-4 text-white text-gradient">
                            {benefit.name}
                        </h3>
                        <p class="text-gray-300 leading-relaxed">
                            {benefit.benefit}
                        </p>
                    </div>
                ))
            }
        </div>

        <!-- Bottom logo-style bar for key tech -->
        <div
            class="mt-20 pt-10 border-t border-white/5 flex flex-wrap justify-center gap-12 opacity-50 grayscale hover:grayscale-0 transition-all duration-700"
        >
            {
                siteData.stackFeaturedTech.map((tech) => (
                    <span class="text-white font-bold tracking-tighter text-2xl">
                        {tech}
                    </span>
                ))
            }
        </div>
    </div>
</section>
