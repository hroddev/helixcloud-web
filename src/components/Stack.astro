---
import { siteData } from "../siteData";
---

<section id="stack" class="py-24 bg-black relative">
    <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
                Por <span class="text-white">qué</span> <span class="text-gradient">HelixCloud</span>
            </h2>
            <p class="text-gray-400 max-w-2xl mx-auto">
                {siteData.stackDescription}
            </p>
        </div>

        <!-- Timeline Horizontal -->
        <div class="max-w-6xl mx-auto">
            <!-- Desktop Timeline -->
            <div class="hidden md:block relative">
                <!-- Connection Line -->
                <div class="absolute top-8 left-0 right-0 h-1 bg-gradient-to-r from-blue-600 via-indigo-600 to-blue-600"></div>

                <!-- Timeline Items -->
                <div class="grid grid-cols-4 gap-6 relative z-10">
                    {
                        siteData.stackBenefits.map((benefit, index) => (
                            <div class="text-center">
                                <!-- Node Circle -->
                                <div class="flex justify-center mb-6">
                                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-600 to-indigo-600 flex items-center justify-center border-4 border-black">
                                        <span class="text-white font-bold text-xl">{index + 1}</span>
                                    </div>
                                </div>

                                <!-- Content -->
                                <h3 class="text-lg font-bold text-white mb-3">
                                    {benefit.name}
                                </h3>
                                <p class="text-gray-400 text-sm leading-relaxed">
                                    {benefit.benefit}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- Mobile Timeline (vertical) -->
            <div class="md:hidden space-y-8 relative">
                <div class="absolute left-8 top-0 bottom-0 w-1 bg-gradient-to-b from-blue-600 to-indigo-600"></div>

                {
                    siteData.stackBenefits.map((benefit, index) => (
                        <div class="pl-24 relative">
                            <!-- Node Circle -->
                            <div class="absolute left-0 w-16 h-16 rounded-full bg-gradient-to-br from-blue-600 to-indigo-600 flex items-center justify-center border-4 border-black">
                                <span class="text-white font-bold">{index + 1}</span>
                            </div>

                            <!-- Content -->
                            <div>
                                <h3 class="text-lg font-bold text-white mb-2">
                                    {benefit.name}
                                </h3>
                                <p class="text-gray-400 text-sm leading-relaxed">
                                    {benefit.benefit}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
